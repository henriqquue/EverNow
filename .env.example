# ===========================================
# EverNOW - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# URL do banco de dados PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Segredo para NextAuth.js (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET="sua-chave-secreta-aqui"

# URL base da aplicação (opcional em dev, obrigatório em produção)
# NEXTAUTH_URL="https://seu-dominio.com"

# Supabase Storage (Para fotos de perfil em produção)
# Obtenha estas chaves em: https://supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://sua-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-aqui"
SUPABASE_STORAGE_BUCKET="profiles" # Nome do bucket criado no Supabase
